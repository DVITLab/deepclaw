# Required
DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=

# Docker build only — OPTIONAL. You do not need a Hugging Face account. Leave empty (as below) for anonymous model download; builds work, may be slower and Hub may log a warning. If you create a free read token at https://huggingface.co/settings/tokens , paste it here for higher rate limits. Compose passes this as a build secret only during `docker compose build` (not stored in image layers).
HF_TOKEN=

# Copy to .env and adjust. Defaults & full list: README § Environment.
# Unset = optional features on (voice, rolling summary, LTM in full mode, DNS check, shell confirm risky only). Set off/0/false to disable what you do not want.
# Resolved values (paths, flags): docker compose exec deepclaw deepclaw doctor

# DEEPCLAW_TZ=Asia/Ho_Chi_Minh
# DEEPCLAW_SAFE_MODE=1
# DEEPCLAW_DATA_DIR=
# DEEPCLAW_WORKSPACE=
# DEEPCLAW_CHAT_HISTORY_DIR=-
# DEEPCLAW_LOG_FILE=-
# DEEPCLAW_PLANNING=0
# DEEPCLAW_PLANNING_REVIEW=0
# DEEPCLAW_TELEGRAM_STREAMING=1
# DEEPCLAW_OCR_LANGS=eng
# DEEPCLAW_VOICE_TRANSCRIPTION=auto
# DEEPCLAW_VOICE_TRANSCRIPTION=0
# DEEPCLAW_WHISPER_PYTHON=/opt/whisper-venv/bin/python
# DEEPCLAW_MAX_MESSAGE_CHARS=32768
# DEEPCLAW_MAX_MESSAGE_CHARS=0
# DEEPCLAW_CHAT_COOLDOWN_MS=500
# DEEPCLAW_RUN_TESTS_TOOL=0
# DEEPCLAW_MAX_PENDING_TURNS_PER_CHAT=8
# DEEPCLAW_MAX_PENDING_TURNS_PER_CHAT=0
# DEEPCLAW_SHUTDOWN_TIMEOUT_MS=30000
# DEEPCLAW_HEALTH_PORT=7587
# DEEPCLAW_HEALTH_PORT=0
# DEEPCLAW_HEALTH_HOST=127.0.0.1
# DEEPCLAW_LLM_CIRCUIT=0
# DEEPCLAW_LLM_CIRCUIT_FAILURE_THRESHOLD=5
# DEEPCLAW_LLM_CIRCUIT_OPEN_MS=60000
# DEEPCLAW_USER_MESSAGE_COOLDOWN_MS=1000
